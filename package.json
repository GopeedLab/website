{
  "name": "gopeed-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/fetch-swagger.mjs",
    "build": "next build",
    "build:worker": "pnpm build && pnpm cf:build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy --minify",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write",
    "db:migrate:dev": "wrangler d1 migrations apply --local gopeed",
    "db:migrate": "wrangler d1 migrations apply --remote gopeed",
    "db:studio:dev": "cross-env LOCAL_DB_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print0 | xargs -0 ls -t | head -1) drizzle-kit studio",
    "sync:extensions": "node scripts/sync-extensions.mjs"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@libsql/client": "^0.17.0",
    "@scalar/nextjs-api-reference": "^0.9.24",
    "drizzle-orm": "^0.45.1",
    "firebase": "^12.10.0",
    "framer-motion": "^11.18.2",
    "fumadocs-core": "16.6.5",
    "fumadocs-mdx": "14.2.8",
    "fumadocs-ui": "16.6.5",
    "lucide-react": "^0.563.0",
    "next": "16.1.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "shiki": "^3.23.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@cloudflare/workers-types": "^4.20260305.0",
    "@opennextjs/cloudflare": "1.15.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.9",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "wrangler": "^4.61.0"
  }
}