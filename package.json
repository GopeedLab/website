{
  "name": "gopeed-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:worker": "pnpm build && pnpm cf:build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "framer-motion": "^11.18.2",
    "fumadocs-core": "16.4.8",
    "fumadocs-mdx": "14.2.6",
    "fumadocs-ui": "16.4.8",
    "lucide-react": "^0.563.0",
    "next": "16.1.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@opennextjs/cloudflare": "1.15.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "wrangler": "^4.61.0"
  }
}
